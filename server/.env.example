# HomeBrain server environment

# HTTP port used by both the API and the production web UI.
PORT=3000

# MongoDB connection string
DATABASE_URL=mongodb://localhost/HomeBrain

# Generate unique random secrets for every deployment.
# Example:
#   openssl rand -hex 32
JWT_SECRET=replace-me-with-a-random-secret
REFRESH_TOKEN_SECRET=replace-me-with-a-random-secret

# Optional: mark cookies as Secure when you are serving over HTTPS.
# COOKIE_SECURE=true

# Optional: public URL for browser redirects and OAuth callbacks.
# CLIENT_URL=https://homebrain.example.com

# Optional cloud providers
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
STT_OPENAI_API_KEY=

# Optional: ElevenLabs API Base URL
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# Optional SmartThings OAuth
# SMARTTHINGS_CLIENT_ID=
# SMARTTHINGS_CLIENT_SECRET=
# SMARTTHINGS_REDIRECT_URI=https://homebrain.example.com/api/smartthings/callback

# Optional Ecobee OAuth
# ECOBEE_CLIENT_ID=
# ECOBEE_REDIRECT_URI=https://homebrain.example.com/api/ecobee/callback

# Caddy reverse-proxy integration
CADDY_ADMIN_URL=http://127.0.0.1:2019
ACME_ENV=staging

# Optional: public origin used for remote-device bootstrap links and webhook/callback URLs.
# Example:
# HOMEBRAIN_PUBLIC_BASE_URL=https://freestonefamily.com
# HOMEBRAIN_EXPECTED_PUBLIC_IP=203.0.113.10
# HOMEBRAIN_EXPECTED_PUBLIC_IPV6=2001:db8::10

# Optional: bind host for the internal HomeBrain HTTP service.
# Leave at 0.0.0.0 if you still want direct LAN access on :3000.
# Set to 127.0.0.1 when all access goes through Caddy.
# HOMEBRAIN_BIND_HOST=0.0.0.0

# Optional default admin bootstrap.
# Existing matching accounts will be promoted to active admins automatically.
# To create the account automatically when it is missing, also set HOMEBRAIN_DEFAULT_ADMIN_PASSWORD.
# Existing admin passwords are left alone unless HOMEBRAIN_DEFAULT_ADMIN_SYNC_PASSWORD=true.
# HOMEBRAIN_DEFAULT_ADMIN_ENABLED=true
# HOMEBRAIN_DEFAULT_ADMIN_EMAIL=matt@freestonefamily.com
# HOMEBRAIN_DEFAULT_ADMIN_NAME=Matt Freestone
# HOMEBRAIN_DEFAULT_ADMIN_PASSWORD=
# HOMEBRAIN_DEFAULT_ADMIN_SYNC_PASSWORD=false
