# Port to listen on (example: 3000)
PORT=3000

# MongoDB database URL (example: mongodb://localhost/dbname)
DATABASE_URL=mongodb://localhost/HomeBrain

# JWT Secrets for authentication
JWT_SECRET=7d0f4cae98da4194b9a0e6b50fa0fb7f
REFRESH_TOKEN_SECRET=42071620dd0440708bc19d310006b643

# ElevenLabs API Configuration
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
# Leave empty to use mock data for development
ELEVENLABS_API_KEY=

# Optional: ElevenLabs API Base URL (defaults to https://api.elevenlabs.io/v1)
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# HTTPS Configuration
# Port for HTTPS server (default: 443)
HTTPS_PORT=443

# ACME HTTP-01 challenge listener (default: 80)
ACME_CHALLENGE_PORT=80

# Optional: Frontend base URL override for OAuth redirects (defaults to request host)
# CLIENT_URL=https://your-domain.com

# Ecobee OAuth Configuration (optional defaults for first-time setup)
# ECOBEE_CLIENT_ID=your-ecobee-app-key
# ECOBEE_REDIRECT_URI=https://your-domain.com/api/ecobee/callback
