# HomeBrain Client Environment Configuration

# API Debug Logging
# Set to 'true' to enable verbose API request/response logging
# Default: undefined (disabled)
# VITE_API_DEBUG=true

# Optional override for device WebSocket / SSE origin in development.
# Only set this if your Vite dev server is not running on the same host as the API.
# VITE_DEVICE_WS_URL=ws://localhost:3000/ws/devices
# VITE_DEVICE_WS_PORT=3000

# Polling Debug Logging
# Set to 'true' to enable verbose polling and component lifecycle logging
# Default: undefined (disabled)
# VITE_POLLING_DEBUG=true

# Note: Debug logging is automatically disabled in production builds
# These variables only work in development mode (NODE_ENV=development)
